# =============================================================================
# RevMine — single configuration file
# =============================================================================
# Copy this file to `.env` at the repo root, fill in the marked values, then:
#     docker compose up
#
# Fill in all values marked with <...> before starting the stack.
#
# Generate the secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"          # SECRET_KEY
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # ENCRYPTION_KEY
# =============================================================================


# ─── Django (shared by authentication, configuration, collection, analyze) ───
SECRET_KEY=<django-secret-key>
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,auth-service,api-gateway,configuration-service,collection-service,analyze-service
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173


# ─── Token encryption (configuration / collection / analyze must agree) ──────
ENCRYPTION_KEY=<fernet-key>


# ─── Postgres credentials (used by every *-db container and Django services) ─
POSTGRES_USER=<postgres-user>
POSTGRES_PASSWORD=<postgres-password>

# DSN used only by the Go notification service.
NOTIFICATION_DATABASE_URL=
GRAFANA_ADMIN_PASSWORD=
SONAR_JDBC_PASSWORD=
TEST_POSTGRES_PASSWORD=


# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# https://github.com/settings/developers  →  New OAuth App
#   Homepage URL:              http://localhost:5173
#   Authorization callback:    http://localhost:5173/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/auth/github/callback


# ─── GitLab OAuth ────────────────────────────────────────────────────────────
# https://gitlab.com/-/user_settings/applications  →  Add new application
#   Redirect URI:  http://localhost:5173/auth/gitlab/callback
#   Scopes:        read_user, read_api, read_repository, api
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:5173/auth/gitlab/callback


# ─── Google OAuth ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials  →  OAuth client ID (Web)
#   Authorized redirect URI:   http://localhost:5173/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback


# ─── MinIO (object storage for collected artifacts) ──────────────────────────
# These boot the MinIO container; the collection-service reuses them as creds.
# Password must be ≥ 8 characters.
MINIO_ROOT_USER=<minio-root-user>
MINIO_ROOT_PASSWORD=<minio-root-password>
MINIO_BUCKET_NAME=revmine-collections
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_SECURE=False


# ─── LLM service ─────────────────────────────────────────────────────────────
# Default routes to the local Ollama container — pull a model with:
#     docker exec -it ollama-service ollama pull deepseek-r1
OLLAMA_DEFAULT_MODEL=deepseek-r1

# Optional: OpenRouter-hosted models. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://localhost/
