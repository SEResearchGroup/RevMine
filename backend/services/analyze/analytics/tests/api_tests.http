###############################################################################
# DATASETS
###############################################################################

### List all datasets
GET {{baseUrl}}/datasets/ HTTP/1.1
Authorization: Bearer {{authToken}}
Content-Type: application/json

### List datasets filtered by workspace
GET {{baseUrl}}/datasets/?workspace_id=1 HTTP/1.1
Content-Type: application/json

### Upload a new dataset (CSV file)
# @name uploadDataset
POST {{baseUrl}}/datasets/upload/ HTTP/1.1
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

