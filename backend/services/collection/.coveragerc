[run]
omit =
    */migrations/*
    */tests/*
    */tests.py
    */test_*.py
    */*_test.py
    */tests_legacy.py
    */conftest.py
    */asgi.py
    */wsgi.py
    */admin.py
    */apps.py
    */schema.py
    */schemas.py
    */logging_utils.py
    */kafka_utils/*
    */collectors/branch_fetcher.py
    */collectors/csv_generator.py
    */collectors/github_collector.py
    */collectors/gitlab_collector.py
    */collectors/kafka_handlers.py
    */collectors/metadata_extractor.py
    */collectors/metrics_config.py
    */collectors/minio_client.py
    */collectors/serializers.py
    */collectors/urls.py
    */collectors/views.py
    */collectors/infrastructure/messaging/*
