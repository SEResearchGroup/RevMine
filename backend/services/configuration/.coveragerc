[run]
omit =
    */migrations/*
    */tests/*
    */tests.py
    */test_*.py
    */*_test.py
    */tests_legacy.py
    */conftest.py
    */asgi.py
    */wsgi.py
    */admin.py
    */apps.py
    */schema.py
    */schemas.py
    */logging_utils.py
    */kafka_utils/*
    */workspaces/kafka_handlers.py
    */workspaces/serializers.py
    */workspaces/views.py
